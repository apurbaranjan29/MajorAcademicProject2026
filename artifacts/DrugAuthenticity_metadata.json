		"userdoc": {
			"kind": "user",
			"methods": {
				"clearFlag(string,uint8)": {
					"notice": "Regulator clears a false-positive counterfeit flag."
				},
				"flagCounterfeit(string,string)": {
					"notice": "Flag a batch as potentially counterfeit.         Any registered user can flag — regulators investigate."
				},
				"getStageHistory(string)": {
					"notice": "Returns the full stage history for a batch.         Powers the supply chain timeline UI on the website."
				},
				"markAsSold(string,uint256)": {
					"notice": "Sell the drug to a patient.         Requires a valid, unexpired prescription.         Calls PrescriptionAndDiagnosis.dispensePrescription() to close the loop."
				},
				"receiveAtPharmacy(string)": {
					"notice": "Pharmacy confirms receipt of the batch.         Only callable by wallets with PHARMACIST_ROLE.         Batch must be InTransit and pharmacy must be the current owner."
				},
				"registerDrug(string,string)": {
					"notice": "Register a new drug batch on-chain.         Only callable by wallets with MANUFACTURER_ROLE."
				},
				"transferToDistributor(string,address)": {
					"notice": "Transfer batch to a distributor.         Only the current owner (manufacturer) can call this.         Recipient must hold DISTRIBUTOR_ROLE."
				},
				"verifyDrug(string)": {
					"notice": "Public drug verification — anyone can call this.         Used by the QR code scanner on the website."
				}
			},
			"version": 1
		}
