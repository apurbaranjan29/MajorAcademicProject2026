		"userdoc": {
			"kind": "user",
			"methods": {
				"addDiagnosis(address,string,string)": {
					"notice": "Add a diagnosis for a patient.         Caller must be a consented doctor."
				},
				"addPrescription(address,string,string,uint256)": {
					"notice": "Add a prescription for a patient."
				},
				"dispensePrescription(uint256)": {
					"notice": "Mark a prescription as dispensed.         Only callable by a registered pharmacist.         Validates the prescription is still ISSUED and not expired.         DrugAuthenticity.sol calls isValidPrescription() before this."
				},
				"expirePrescription(uint256)": {
					"notice": "Mark a prescription as EXPIRED.         Anyone can call this on an overdue prescription (used by bots / cron)."
				},
				"getDiagnosesByPatient(address)": {
					"notice": "Returns all diagnosis IDs for a patient"
				},
				"getPrescription(uint256)": {
					"notice": "Returns full prescription struct — called by DrugAuthenticity         to get the patient address for validation."
				},
				"getPrescriptionsByPatient(address)": {
					"notice": "Returns all prescription IDs for a patient"
				},
				"isValidPrescription(uint256)": {
					"notice": "Primary cross-contract check used by DrugAuthenticity.         Returns true only if prescription is ISSUED and not expired."
				}
			},
			"version": 1
		}
