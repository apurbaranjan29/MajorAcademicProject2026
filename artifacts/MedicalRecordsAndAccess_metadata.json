		"userdoc": {
			"kind": "user",
			"methods": {
				"addMedicalRecord(address,string,string)": {
					"notice": "Add a medical record for a patient.         Caller must hold valid patient consent."
				},
				"getLatestVersion(address)": {
					"notice": "Returns the latest version number of a patient's records.         Useful for checking if a patient's records have been updated."
				},
				"getRecordCount(address)": {
					"notice": "Returns the total number of records for a patient."
				},
				"getRecordsByPatient(address)": {
					"notice": "Returns all record IDs belonging to a patient.         Frontend uses this to paginate a patient's record history."
				},
				"updateMedicalRecord(uint256,string)": {
					"notice": "Allows the original doctor to correct a faulty record. The old hash is permanently logged in the event history for auditing."
				},
				"viewMedicalRecord(uint256,string)": {
					"notice": "View a specific medical record and emit an access log.         Requires valid patient consent."
				}
			},
			"version": 1
		}
