		"devdoc": {
			"kind": "dev",
			"methods": {
				"logVitalsBatch(string)": {
					"params": {
						"ipfsHash": "IPFS CID of the encrypted vitals JSON batch"
					}
				},
				"triggerAlert(address,string,uint256,uint256,string)": {
					"params": {
						"alertType": "String label: \"HR_HIGH\", \"HR_LOW\", \"SPO2_LOW\", etc.",
						"patient": "Patient being monitored",
						"severity": "\"WARNING\" or \"CRITICAL\"",
						"threshold": "The threshold constant that was crossed",
						"value": "The actual sensor reading that triggered the alert"
					}
				}
			},
			"version": 1
		},
		"userdoc": {
			"kind": "user",
			"methods": {
				"checkHeartRate(uint256)": {
					"notice": "Returns whether a heart rate reading crosses any threshold.         The backend can call this as a view before deciding to triggerAlert."
				},
				"deregisterDevice(address)": {
					"notice": "Remove a device from the whitelist (lost / replaced / retired)"
				},
				"getAlertsByPatient(address)": {
					"notice": "Returns all alert IDs for a patient"
				},
				"getLatestLog(address)": {
					"notice": "Returns the latest log for a patient (most recent vitals)"
				},
				"getLogsByPatient(address)": {
					"notice": "Returns all vitals log IDs for a patient"
				},
				"getThresholds()": {
					"notice": "Returns threshold constants as a struct for frontend display"
				},
				"logVitalsBatch(string)": {
					"notice": "Log a batch of vitals readings anchored by their IPFS hash.         Called by the Node.js IoT ingestion service after encrypting         and uploading the readings to IPFS."
				},
				"registerDevice(address,address)": {
					"notice": "Register a new IoT device and associate it with a patient.         The device address is the wallet used by the backend IoT bridge."
				},
				"triggerAlert(address,string,uint256,uint256,string)": {
					"notice": "Trigger a threshold alert.         Called by the Node.js backend when it detects a threshold         crossing in the raw sensor data BEFORE uploading to IPFS.         The alert is stored on-chain for an immutable audit record."
				}
			},
			"version": 1
		}
